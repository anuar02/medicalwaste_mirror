{
  "expo": {
    "name": "Medical Waste",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcompany.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera access is needed to scan QR codes.",
        "NSLocationWhenInUseUsageDescription": "We use your location to show nearby containers.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "We use your location to track active collections."
      }
    },
    "android": {
      "package": "com.yourcompany.mobile",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Camera access is needed to scan QR codes.",
          "recordAudioAndroid": false
        }
      ],
      "expo-location",
      "expo-dev-client"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
